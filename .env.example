# =============================================================
# Google Ad Performance Analyzer - Environment Configuration
# =============================================================
# Copy this file to .env and fill in your API key.
#
# Get your OpenAI API key at: https://platform.openai.com/api-keys
# Get your Google Gemini API key at: https://aistudio.google.com/apikey
# =============================================================

# --- LLM Provider (choose one: "openai" or "gemini") ---
LLM_PROVIDER=openai

# --- OpenAI Configuration ---
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4o-mini

# --- Google Gemini Configuration (alternative) ---
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-1.5-flash

# --- Dataset path (relative to project root) ---
DATASET_PATH=GoogleAds_DataAnalytics_Sales_Uncleaned.csv
